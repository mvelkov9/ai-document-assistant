# Production environment configuration
# Copy to .env and fill in real values before deploying.
# NEVER commit the real .env to version control.

# ── App ──
PROJECT_NAME=AI Document Assistant
APP_ENV=production
SECRET_KEY=<generate-a-strong-random-key-here>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── PostgreSQL (used by docker-compose AND backend) ──
POSTGRES_DB=docassist
POSTGRES_USER=docassist
POSTGRES_PASSWORD=STRONG_DB_PASSWORD
DATABASE_URL=postgresql+psycopg://docassist:STRONG_DB_PASSWORD@postgres:5432/docassist

# ── MinIO object storage ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=STRONG_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=STRONG_MINIO_PASSWORD
MINIO_BUCKET=documents
MINIO_SECURE=false
# Ports are not exposed in production, but needed to avoid warnings
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── AI provider (priority: Groq → Gemini → OpenAI → fallback) ──
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SUMMARY_MAX_CHARS=6000

# ── Frontend build arg (prod overlay hardcodes this, but avoids warning) ──
VITE_API_BASE_URL=/api/v1

# ── Upload limit ──
MAX_UPLOAD_SIZE_MB=15

# ── CORS ──
CORS_ORIGINS=["https://yourdomain.com"]
